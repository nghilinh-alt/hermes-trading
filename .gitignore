# Python virtual environment and cache
venv/
__pycache__/
*.py[cod]
*$py.class
.Python

# IDE settings
.idea/
.vscode/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Environment variables (secrets)
.env
state/.env

# Trading state and logs (optional - remove from git if not tracked)
state/*.json
!state/goal.yaml  # Keep goal config tracked
!state/strategy.yaml  # Keep strategy config tracked
state/*.log
!.gitkeep  # Allow .gitkeep marker file
