# Hermes Trading — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ── Trading mode ──────────────────────────────────────────────────────────────
HERMES_TRADING_MODE=live
HERMES_TRADING_I_ACCEPT_RISK=true

# ── Bybit API credentials ─────────────────────────────────────────────────────
# Create at: https://www.bybit.com/app/user/api-management
# Permissions needed: Contract - Orders (Read + Write), Positions (Read)
BYBIT_API_KEY=your_api_key_here
BYBIT_RSA_PRIVATE_KEY_PATH=/opt/trading/hermes_trading/bybit_private.pem

# ── Risk controls ─────────────────────────────────────────────────────────────
# Position size as a fraction of your total USDT balance (0.20 = 20%)
MAX_POSITION_PCT=0.20

# Leverage range — bot scales within this band based on signal strength
# Stronger RSI signal (lower RSI for longs) → higher leverage, up to MAX
MIN_LEVERAGE=3
MAX_LEVERAGE=15
