# Hermes Trading — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# ── Trading mode ──────────────────────────────────────────────────────────────
HERMES_TRADING_MODE=live
HERMES_TRADING_I_ACCEPT_RISK=true

# ── Bybit API credentials ─────────────────────────────────────────────────────
# Create at: https://www.bybit.com/app/user/api-management
# Permissions needed: Contract - Orders (Read + Write), Positions (Read)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# ── Risk controls ─────────────────────────────────────────────────────────────
# Maximum USD value per position (e.g. 100 = $100 per trade)
MAX_POSITION_USD=100
